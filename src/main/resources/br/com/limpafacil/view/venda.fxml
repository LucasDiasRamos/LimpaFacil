<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.GridPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<BorderPane xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="br.com.limpafacil.controller.VendaController">
    <left>
        <VBox spacing="10" styleClass="sidebar">
            <padding>
                <Insets top="22" right="16" bottom="22" left="16"/>
            </padding>
            <Label text="LimpaFácil" styleClass="sidebar-title"/>
            <Button text="Dashboard" onAction="#voltarDashboard" maxWidth="Infinity" styleClass="nav-button"/>
            <Button text="Registrar Venda" maxWidth="Infinity" styleClass="nav-button"/>
            <Button text="Categorias" onAction="#abrirCategorias" maxWidth="Infinity" styleClass="nav-button"/>
            <Button text="Produtos" onAction="#abrirProdutos" maxWidth="Infinity" styleClass="nav-button"/>
            <Button text="Sair" onAction="#sair" maxWidth="Infinity" styleClass="nav-button"/>
        </VBox>
    </left>

    <center>
        <VBox spacing="14" styleClass="page">
            <padding>
                <Insets top="24" right="28" bottom="24" left="28"/>
            </padding>

            <Label text="Registrar Venda" styleClass="page-title"/>

            <HBox spacing="10">
                <TextField fx:id="buscaProdutoField" promptText="Buscar produto por código ou nome" prefWidth="340" onAction="#buscarProdutos"/>
                <Button text="Buscar" onAction="#buscarProdutos"/>
                <TextField fx:id="quantidadeField" promptText="Quantidade" prefWidth="120" onAction="#adicionarItem"/>
                <Button text="Adicionar item" onAction="#adicionarItem" styleClass="primary-button"/>
            </HBox>

            <TableView fx:id="produtosTable" prefHeight="170">
                <columns>
                    <TableColumn fx:id="produtoCodigoColumn" text="Código" prefWidth="120"/>
                    <TableColumn fx:id="produtoNomeColumn" text="Produto" prefWidth="300"/>
                    <TableColumn fx:id="produtoPrecoColumn" text="Preço" prefWidth="120"/>
                    <TableColumn fx:id="produtoEstoqueColumn" text="Estoque" prefWidth="100"/>
                </columns>
            </TableView>

            <Label text="Itens da venda" styleClass="section-title"/>
            <TableView fx:id="itensTable" VBox.vgrow="ALWAYS">
                <columns>
                    <TableColumn fx:id="itemCodigoColumn" text="Código" prefWidth="120"/>
                    <TableColumn fx:id="itemNomeColumn" text="Produto" prefWidth="300"/>
                    <TableColumn fx:id="itemQuantidadeColumn" text="Qtd" prefWidth="80"/>
                    <TableColumn fx:id="itemPrecoColumn" text="Unitário" prefWidth="120"/>
                    <TableColumn fx:id="itemSubtotalColumn" text="Subtotal" prefWidth="120"/>
                </columns>
            </TableView>

            <GridPane hgap="12" vgap="8">
                <Label text="Forma de pagamento" GridPane.rowIndex="0" GridPane.columnIndex="0"/>
                <ComboBox fx:id="formaPagamentoComboBox" prefWidth="220" GridPane.rowIndex="1" GridPane.columnIndex="0"/>

                <Label text="Valor recebido" GridPane.rowIndex="0" GridPane.columnIndex="1"/>
                <TextField fx:id="valorRecebidoField" promptText="Obrigatório para dinheiro" prefWidth="180" GridPane.rowIndex="1" GridPane.columnIndex="1"/>

                <Label text="Total" GridPane.rowIndex="0" GridPane.columnIndex="2"/>
                <Label fx:id="totalLabel" text="R$ 0,00" styleClass="total-label" GridPane.rowIndex="1" GridPane.columnIndex="2"/>

                <Label text="Troco" GridPane.rowIndex="0" GridPane.columnIndex="3"/>
                <Label fx:id="trocoLabel" text="R$ 0,00" styleClass="total-label" GridPane.rowIndex="1" GridPane.columnIndex="3"/>
            </GridPane>

            <HBox spacing="10">
                <Button text="Confirmar venda" onAction="#confirmarVenda" styleClass="primary-button"/>
                <Button text="Remover item" onAction="#removerItem"/>
                <Button text="Cancelar venda" onAction="#cancelarVenda" styleClass="danger-button"/>
            </HBox>

            <Label fx:id="mensagemLabel" styleClass="message-label"/>
        </VBox>
    </center>
</BorderPane>
