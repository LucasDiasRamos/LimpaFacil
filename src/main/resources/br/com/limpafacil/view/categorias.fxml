<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.GridPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<BorderPane xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="br.com.limpafacil.view.CategoriaViewController">
    <left>
        <VBox spacing="10" styleClass="sidebar">
            <padding>
                <Insets top="22" right="16" bottom="22" left="16"/>
            </padding>
            <Label text="LimpaFácil" styleClass="sidebar-title"/>
            <Button text="Dashboard" onAction="#voltarDashboard" maxWidth="Infinity" styleClass="nav-button"/>
            <Button text="Registrar Venda" onAction="#abrirVenda" maxWidth="Infinity" styleClass="nav-button"/>
            <Button text="Categorias" maxWidth="Infinity" styleClass="nav-button"/>
            <Button text="Produtos" onAction="#abrirProdutos" maxWidth="Infinity" styleClass="nav-button"/>
            <Button text="Sair" onAction="#sair" maxWidth="Infinity" styleClass="nav-button"/>
        </VBox>
    </left>

    <center>
        <VBox spacing="16" styleClass="page">
            <padding>
                <Insets top="24" right="28" bottom="24" left="28"/>
            </padding>

            <Label text="Categorias" styleClass="page-title"/>

            <GridPane hgap="12" vgap="10">
                <Label text="Código" GridPane.rowIndex="0" GridPane.columnIndex="0"/>
                <TextField fx:id="codigoField" promptText="CAT001" GridPane.rowIndex="1" GridPane.columnIndex="0"/>
                <Label text="Nome" GridPane.rowIndex="0" GridPane.columnIndex="1"/>
                <TextField fx:id="nomeField" promptText="Nome da categoria" prefWidth="320" GridPane.rowIndex="1" GridPane.columnIndex="1"/>
            </GridPane>

            <HBox spacing="10">
                <Button text="Salvar" onAction="#salvar" styleClass="primary-button"/>
                <Button text="Limpar" onAction="#limpar"/>
                <Button text="Excluir" onAction="#excluir" styleClass="danger-button"/>
            </HBox>

            <HBox spacing="10">
                <TextField fx:id="buscaField" promptText="Buscar por código ou nome" prefWidth="320" onAction="#buscar"/>
                <Button text="Buscar" onAction="#buscar"/>
            </HBox>

            <Label fx:id="mensagemLabel" styleClass="message-label"/>

            <TableView fx:id="categoriasTable" VBox.vgrow="ALWAYS">
                <columns>
                    <TableColumn fx:id="codigoColumn" text="Código" prefWidth="160"/>
                    <TableColumn fx:id="nomeColumn" text="Nome" prefWidth="420"/>
                </columns>
            </TableView>
        </VBox>
    </center>
</BorderPane>
