<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<BorderPane xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="br.com.limpafacil.view.OrcamentoViewController">
    <left>
        <VBox spacing="10" styleClass="sidebar">
            <padding><Insets top="22" right="16" bottom="22" left="16"/></padding>
            <Label text="LimpaFácil" styleClass="sidebar-title"/>
            <Button text="Dashboard" onAction="#voltarDashboard" maxWidth="Infinity" styleClass="nav-button"/>
        </VBox>
    </left>
    <center>
        <VBox spacing="14" styleClass="page">
            <padding><Insets top="24" right="28" bottom="24" left="28"/></padding>
            <Label text="Orçamentos" styleClass="page-title"/>
            <HBox spacing="10">
                <ComboBox fx:id="clienteComboBox" promptText="Cliente opcional" prefWidth="260"/>
                <TextField fx:id="buscaProdutoField" promptText="Buscar produto" prefWidth="300" onAction="#buscarProdutos"/>
                <Button text="Buscar" onAction="#buscarProdutos"/>
                <TextField fx:id="quantidadeField" promptText="Quantidade" prefWidth="120"/>
                <Button text="Adicionar" onAction="#adicionarItem" styleClass="primary-button"/>
            </HBox>
            <TableView fx:id="produtosTable" prefHeight="180">
                <columns>
                    <TableColumn fx:id="produtoCodigoColumn" text="Código" prefWidth="120"/>
                    <TableColumn fx:id="produtoNomeColumn" text="Produto" prefWidth="320"/>
                    <TableColumn fx:id="produtoPrecoColumn" text="Preço" prefWidth="120"/>
                </columns>
            </TableView>
            <Label text="Itens do orçamento" styleClass="section-title"/>
            <TableView fx:id="itensTable" VBox.vgrow="ALWAYS">
                <columns>
                    <TableColumn fx:id="itemProdutoColumn" text="Produto" prefWidth="360"/>
                    <TableColumn fx:id="itemQuantidadeColumn" text="Qtd" prefWidth="100"/>
                    <TableColumn fx:id="itemSubtotalColumn" text="Subtotal" prefWidth="140"/>
                </columns>
            </TableView>
            <HBox spacing="12">
                <Label text="Total:" styleClass="section-title"/>
                <Label fx:id="totalLabel" text="R$ 0,00" styleClass="total-label"/>
                <Button text="Registrar orçamento" onAction="#registrarOrcamento" styleClass="primary-button"/>
                <Button text="Remover item" onAction="#removerItem"/>
            </HBox>
            <Label fx:id="mensagemLabel" styleClass="message-label"/>
        </VBox>
    </center>
</BorderPane>
