<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.CheckBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.GridPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<BorderPane xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="br.com.limpafacil.view.ClienteViewController">
    <left>
        <VBox spacing="10" styleClass="sidebar">
            <padding><Insets top="22" right="16" bottom="22" left="16"/></padding>
            <Label text="LimpaFácil" styleClass="sidebar-title"/>
            <Button text="Dashboard" onAction="#voltarDashboard" maxWidth="Infinity" styleClass="nav-button"/>
            <Button text="Registrar Venda" onAction="#abrirVenda" maxWidth="Infinity" styleClass="nav-button"/>
            <Button text="Produtos" onAction="#abrirProdutos" maxWidth="Infinity" styleClass="nav-button"/>
        </VBox>
    </left>
    <center>
        <VBox spacing="14" styleClass="page">
            <padding><Insets top="24" right="28" bottom="24" left="28"/></padding>
            <Label text="Clientes" styleClass="page-title"/>
            <GridPane hgap="12" vgap="8">
                <TextField fx:id="codigoField" promptText="Código" GridPane.rowIndex="0" GridPane.columnIndex="0"/>
                <TextField fx:id="nomeField" promptText="Nome" prefWidth="240" GridPane.rowIndex="0" GridPane.columnIndex="1"/>
                <TextField fx:id="cpfCnpjField" promptText="CPF/CNPJ" GridPane.rowIndex="0" GridPane.columnIndex="2"/>
                <TextField fx:id="telefoneField" promptText="Telefone" GridPane.rowIndex="0" GridPane.columnIndex="3"/>
                <TextField fx:id="enderecoField" promptText="Endereço" GridPane.rowIndex="1" GridPane.columnIndex="0"/>
                <TextField fx:id="cidadeField" promptText="Cidade" GridPane.rowIndex="1" GridPane.columnIndex="1"/>
                <TextField fx:id="estadoField" promptText="UF" prefWidth="70" GridPane.rowIndex="1" GridPane.columnIndex="2"/>
                <TextField fx:id="emailField" promptText="E-mail" GridPane.rowIndex="1" GridPane.columnIndex="3"/>
            </GridPane>
            <CheckBox fx:id="ativoCheckBox" text="Cliente ativo"/>
            <HBox spacing="10">
                <Button text="Salvar" onAction="#salvar" styleClass="primary-button"/>
                <Button text="Limpar" onAction="#limpar"/>
                <Button text="Inativar" onAction="#inativar" styleClass="danger-button"/>
            </HBox>
            <HBox spacing="10">
                <TextField fx:id="buscaField" promptText="Buscar por código, nome ou CPF/CNPJ" prefWidth="360" onAction="#buscar"/>
                <Button text="Buscar" onAction="#buscar"/>
            </HBox>
            <Label fx:id="mensagemLabel" styleClass="message-label"/>
            <TableView fx:id="clientesTable" VBox.vgrow="ALWAYS">
                <columns>
                    <TableColumn fx:id="codigoColumn" text="Código" prefWidth="100"/>
                    <TableColumn fx:id="nomeColumn" text="Nome" prefWidth="220"/>
                    <TableColumn fx:id="documentoColumn" text="CPF/CNPJ" prefWidth="150"/>
                    <TableColumn fx:id="cidadeColumn" text="Cidade" prefWidth="150"/>
                    <TableColumn fx:id="telefoneColumn" text="Telefone" prefWidth="130"/>
                    <TableColumn fx:id="ativoColumn" text="Ativo" prefWidth="80"/>
                </columns>
            </TableView>
        </VBox>
    </center>
</BorderPane>
